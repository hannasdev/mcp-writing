{
  "name": "@hanna84/mcp-writing",
  "version": "2.12.8",
  "description": "MCP service for AI-assisted reasoning and editing on long-form fiction projects",
  "homepage": "https://hannasdev.github.io/mcp-writing/",
  "type": "module",
  "main": "index.js",
  "exports": {
    ".": "./index.js",
    "./index.js": "./index.js",
    "./async-jobs.js": "./async-jobs.js",
    "./async-progress.js": "./async-progress.js",
    "./helpers.js": "./helpers.js",
    "./scene-character-batch.js": "./scene-character-batch.js",
    "./scrivener-direct.js": "./scrivener-direct.js",
    "./importer.js": "./importer.js",
    "./db.js": "./db.js",
    "./sync.js": "./sync.js",
    "./git.js": "./git.js",
    "./world-entity-templates.js": "./world-entity-templates.js",
    "./workflow-catalogue.js": "./workflow-catalogue.js",
    "./runtime-diagnostics.js": "./runtime-diagnostics.js",
    "./metadata-lint.js": "./metadata-lint.js",
    "./scene-character-normalization.js": "./scene-character-normalization.js",
    "./review-bundles.js": "./review-bundles.js",
    "./review-bundles-planner.js": "./review-bundles-planner.js",
    "./review-bundles-renderer.js": "./review-bundles-renderer.js",
    "./review-bundles-writer.js": "./review-bundles-writer.js",
    "./prose-styleguide.js": "./prose-styleguide.js",
    "./prose-styleguide-drift.js": "./prose-styleguide-drift.js",
    "./prose-styleguide-skill.js": "./prose-styleguide-skill.js",
    "./tools/*": "./tools/*",
    "./scripts/*": "./scripts/*",
    "./src/*": "./src/*",
    "./package.json": "./package.json"
  },
  "bin": {
    "mcp-writing": "./bin/mcp-writing.js"
  },
  "mcpName": "io.github.hannasdev/mcp-writing",
  "files": [
    "bin/",
    "index.js",
    "src/",
    "async-jobs.js",
    "async-progress.js",
    "helpers.js",
    "scene-character-batch.js",
    "scrivener-direct.js",
    "importer.js",
    "db.js",
    "sync.js",
    "git.js",
    "world-entity-templates.js",
    "workflow-catalogue.js",
    "runtime-diagnostics.js",
    "metadata-lint.js",
    "scene-character-normalization.js",
    "review-bundles.js",
    "review-bundles-planner.js",
    "review-bundles-renderer.js",
    "review-bundles-writer.js",
    "prose-styleguide.js",
    "prose-styleguide-drift.js",
    "prose-styleguide-skill.js",
    "scripts/",
    "tools/",
    "README.md",
    "CHANGELOG.md"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "start": "node --experimental-sqlite index.js",
    "new:entity": "node scripts/new-world-entity.js",
    "manual:realtest": "node scripts/manual-scrivener-realtest.mjs",
    "manual:test": "node scripts/manual/test.mjs",
    "manual:scenarios": "node scripts/manual/test-scenarios.mjs",
    "manual:merge-beta-test": "node scripts/manual/run_mcp_test.js",
    "manual:review-bundle": "node scripts/manual/run_create_review_bundle.js",
    "normalize:scene-characters": "node --experimental-sqlite scripts/normalize-scene-characters.mjs",
    "setup:openclaw-env": "sh scripts/setup-openclaw-env.sh",
    "release": "release-it",
    "lint": "eslint *.js src/ scripts/ tools/",
    "docs": "node scripts/generate-tool-docs.mjs",
    "lint:metadata": "node scripts/lint-metadata.mjs",
    "sync:server-json-version": "node scripts/sync-server-json-version.mjs",
    "test:unit": "node --experimental-sqlite --test test/unit/*.test.mjs",
    "test:integration": "node --experimental-sqlite --test --test-concurrency=1 test/integration/*.test.mjs",
    "test": "npm run test:unit && npm run test:integration"
  },
  "keywords": [
    "mcp",
    "writing",
    "fiction",
    "ai",
    "scrivener"
  ],
  "license": "AGPL-3.0-only",
  "repository": {
    "type": "git",
    "url": "https://github.com/hannasdev/mcp-writing"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@xmldom/xmldom": "^0.9.10",
    "gray-matter": "^4.0.3",
    "js-yaml": "^4.1.1",
    "pdfkit": "^0.14.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "auto-changelog": "^2.5.0",
    "eslint": "^10.2.0",
    "globals": "^17.5.0",
    "release-it": "^20.0.0"
  }
}
